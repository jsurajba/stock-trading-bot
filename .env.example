# ==============================================================================
# Stock Trading Bot Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit your '.env' file containing secrets to version control.
# ==============================================================================

# 1. LLM Decision Provider Configuration
# Supported providers: gemini, anthropic
LLM_PROVIDER=gemini

# Model name configuration based on the chosen provider:
# Gemini: gemini-3.5-flash, gemini-3.1-pro
# Claude: claude-4.7-sonnet, claude-4.8-opus
LLM_MODEL=gemini-3.5-flash

# 2. Chatbot API Credentials
# Google AI Studio API Key (for LLM_PROVIDER=gemini): https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Anthropic Console API Key (for LLM_PROVIDER=anthropic): https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# 3. Alpaca Securities Configuration
# Get your API keys from the Alpaca Dashboard: https://app.alpaca.markets/
ALPACA_KEY_ID=YOUR_ALPACA_KEY_ID_HERE
ALPACA_SECRET=YOUR_ALPACA_SECRET_HERE

# 4. Discord Telemetry Integration (Optional)
# Create a webhook in your Discord server channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
